{
  "name": "@talp2/backend",
  "version": "0.1.0",
  "private": true,
  "description": "TALP2 backend — Node.js + TypeScript (Express) API with JSON persistence",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test:acceptance": "cucumber-js"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.8.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
